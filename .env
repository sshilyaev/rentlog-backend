APP_SECRET=change-me
APP_ENV=prod
APP_DEBUG=0

DEFAULT_URI=https://example.com

POSTGRES_DB=rentlog
POSTGRES_USER=rentlog
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://rentlog:change-me@postgres:5432/rentlog?serverVersion=17&charset=utf8

REDIS_URL=redis://redis:6379

JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=

WEB_PROFILER_ENABLED=0
PROFILER_HTTP_PASSWORD=
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=
DEFAULT_ADMIN_FULL_NAME=Administrator

###> symfony/mailer ###
MAILER_DSN=null://null
MAILER_FROM="Rentlog <noreply@example.com>"
# В dev с null://null или AUTO_VERIFY_EMAIL=1 письма не обязательны — email считается подтверждённым при регистрации.
AUTO_VERIFY_EMAIL=0
###< symfony/mailer ###
